# Databáze
DATABASE_URL=postgres://contactbook:HESLO@localhost:5432/contactbook

# Redis
REDIS_URL=redis://:HESLO@localhost:6379

# JWT - vygeneruj náhodné tajné klíče (min. 32 znaků)
# Příkaz: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=VYGENERUJ_NAHODNY_KLIC_MIN_32_ZNAKU
JWT_REFRESH_SECRET=VYGENERUJ_JINY_NAHODNY_KLIC_MIN_32_ZNAKU

# Server
PORT=3000
NODE_ENV=production

# CORS - URL tvé frontendové aplikace
CORS_ORIGIN=https://TVOJE_DOMENA.COM

# Produkční proměnné pro docker-compose.prod.yml
DB_USER=contactbook
DB_PASSWORD=SILNE_HESLO_PRO_DB
DB_NAME=contactbook
REDIS_PASSWORD=SILNE_HESLO_PRO_REDIS
APP_URL=https://TVOJE_DOMENA.COM
API_URL=https://TVOJE_DOMENA.COM/api
