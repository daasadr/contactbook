# Produkční prostředí pro docker-compose.prod.yml
# Zkopírovat jako .env a vyplnit hodnoty

# Databáze
DB_USER=contactbook
DB_PASSWORD=VYGENERUJ_SILNE_HESLO
DB_NAME=contactbook

# Redis
REDIS_PASSWORD=VYGENERUJ_SILNE_HESLO

# JWT klíče — každý min. 32 náhodných znaků
# Generování: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=VYGENERUJ_NAHODNY_KLIC
JWT_REFRESH_SECRET=VYGENERUJ_JINY_NAHODNY_KLIC

# URL tvé aplikace (i bez domény zatím IP)
APP_URL=http://188.245.190.72
API_URL=http://188.245.190.72/api
